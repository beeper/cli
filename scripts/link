#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/beeper/desktop-api-go/v5,github.com/stainless-sdks/beeper-desktop-api-go/v5"

REPLACEMENT="${1:-"../beeperdesktop-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
if [[ -d "$REPLACEMENT" ]] || go list -m "$REPLACEMENT" >/dev/null; then
    go mod edit -replace github.com/beeper/desktop-api-go/v5="$REPLACEMENT"
    go mod tidy -e
else
    echo "Skipping Go SDK replacement (branch may not exist on Go SDK)"
fi
