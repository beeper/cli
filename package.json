{
  "name": "desktop-api-cli-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "trustedDependencies": [
    "@beeper/desktop-api"
  ],
  "scripts": {
    "build": "bun --workspaces run build",
    "check": "bun run typecheck && bun run test && bun run build && bun run pack:packages",
    "clean": "bun --workspaces run clean",
    "changeset": "changeset",
    "lint": "eslint eslint.config.mjs packages/cli-plugin-cloudflare/src packages/cli-plugin-cloudflare/test",
    "pack:packages": "mkdir -p .packs && bun --filter beeper-cli pm pack --destination ../../.packs && bun --filter @beeper/cli-plugin-cloudflare pm pack --destination ../../.packs",
    "release": "bun run check && bun changeset publish",
    "test": "bun --workspaces run test",
    "typecheck": "bun --workspaces run typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.3",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-config-oclif": "^6.0.165",
    "eslint-config-prettier": "^10.1.8",
    "tsdown": "^0.21.10",
    "typescript": "^5.7.2"
  }
}
